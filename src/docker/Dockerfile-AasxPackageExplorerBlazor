# AASX Package Explorer — Blazor Server (HTML UI)
# Repo: https://github.com/eclipse-aaspe/package-explorer
# Kontext: Repository-Root (wie bei Dockerfile-AasxServerBlazor).
#
# Remote + Branch AnyUiAO (Ubuntu / amd64):
#   docker build --platform linux/amd64 \
#     -t adminshellio/aasx-package-explorer-blazor:develop \
#     -f src/docker/Dockerfile-AasxPackageExplorerBlazor \
#     "https://github.com/eclipse-aaspe/package-explorer.git#AnyUiAO"
#
# Lokal (Branch AnyUiAO auschecken):
#   docker build --platform linux/amd64 \
#     -t adminshellio/aasx-package-explorer-blazor:develop \
#     -f src/docker/Dockerfile-AasxPackageExplorerBlazor .

FROM mcr.microsoft.com/dotnet/sdk:9.0 AS build
WORKDIR /src

COPY src/ src/

RUN dotnet restore src/BlazorExplorer/BlazorExplorer.csproj

RUN dotnet publish src/BlazorExplorer/BlazorExplorer.csproj \
    -c Release \
    -o /app/publish \
    --no-restore \
    /p:UseAppHost=false

FROM mcr.microsoft.com/dotnet/aspnet:9.0 AS final
WORKDIR /app

COPY --from=build /app/publish .

ENV ASPNETCORE_URLS=http://+:8080
ENV ASPNETCORE_ENVIRONMENT=Production

EXPOSE 8080

ENTRYPOINT ["dotnet", "BlazorExplorer.dll"]
