@using AdminShellNS
@using Aas = AasCore.Aas3_1
@using AdminShellNS;
@using Extensions
@using AnyUi
@using BlazorUI.Data
@inject BlazorUI.Data.AASService SubmodelService

@{
    // resharper disable all

    if (_grid == null)
        return;

    // ---------------------------------------------------------------
    // Build CSS Grid column template
    // Rules:
    //   Star    → minmax(0, Nfr)       – shrinks to 0, expands proportionally
    //   Pixel   → Xpx                  – fixed width
    //   Auto + MinWidth → fit-content(Xpx) – natural size capped at MinWidth
    //                                        (prevents long labels from eating button space)
    //   Auto only → max-content        – natural size
    //
    // When no Star column exists, append a "1fr" spacer so the grid fills the
    // available width (mirrors the old extra-column trick for pure-auto grids).
    // ---------------------------------------------------------------

    var _tmplParts = new List<string>();
    var _sumOfStars = 0.0;
    if (_grid.ColumnDefinitions != null)
        foreach (var _cd in _grid.ColumnDefinitions)
            if (_cd?.Width?.Type == AnyUiGridUnitType.Star)
                _sumOfStars += _cd.Width.Value;
    var _hasStarCol = _sumOfStars > 0.001;

    if (_grid.ColumnDefinitions != null)
        foreach (var _tcd in _grid.ColumnDefinitions)
        {
            if (_tcd.Width?.Type == AnyUiGridUnitType.Star)
            {
                // keep value for multi-star grids (e.g. "2*" and "1*" → 2fr, 1fr)
                var _starVal = FormattableString.Invariant($"{_tcd.Width.Value:0.###}");
                _tmplParts.Add($"minmax(0, {_starVal}fr)");
            }
            else if (_tcd.Width?.Type == AnyUiGridUnitType.Pixel)
            {
                var _px = (_grid.DisplayData as AnyUiDisplayDataHtml)?.ScaleToPixel(_tcd.Width.Value) ?? _tcd.Width.Value;
                _tmplParts.Add(FormattableString.Invariant($"{(int)_px}px"));
            }
            else if (_tcd.MinWidth.HasValue)
            {
                // fit-content caps the column at MinWidth → long labels cannot push
                // buttons out of their 1fr column even on narrow panes
                var _minpx = (_grid.DisplayData as AnyUiDisplayDataHtml)?.ScaleToPixel(_tcd.MinWidth.Value) ?? _tcd.MinWidth.Value;
                _tmplParts.Add(FormattableString.Invariant($"fit-content({(int)_minpx}px)"));
            }
            else
            {
                _tmplParts.Add("max-content");
            }
        }

    if (!_hasStarCol)
        _tmplParts.Add("1fr");   // spacer so the grid fills available width

    var _cssTemplate = string.Join(" ", _tmplParts);

    // ---------------------------------------------------------------
    // Grid container style
    // ---------------------------------------------------------------

    // Inline-grid for left/right aligned grids (was display:inline-table)
    var _isInline =
        _grid.HorizontalAlignment.HasValue &&
        (_grid.HorizontalAlignment.Value == AnyUiHorizontalAlignment.Left ||
         _grid.HorizontalAlignment.Value == AnyUiHorizontalAlignment.Right);

    var _gridStyle = new StylePile();
    _gridStyle.Set("display", _isInline ? "inline-grid" : "grid", add: true);
    _gridStyle.Set("grid-template-columns", _cssTemplate, add: true);
    _gridStyle.Set(_isInline ? "width" : "width", _isInline ? "max-content" : "100%", add: true);
    _gridStyle.Set("min-width", "0", add: true);
    _gridStyle.Set("align-items", "center", add: true);
    _gridStyle.Set("box-sizing", "border-box", add: true);

    if (_grid.Background != null)
        _gridStyle.Add("background-color", _grid.Background.HtmlRgb());

    if (AnyUiDisplayDataHtml.DebugFrames)
        _gridStyle.Set("border", "1px solid black", add: true);

    if (_grid.BackgroundImageHtml != null)
    {
        var _imgPath = "/api/image/" + _grid.BackgroundImageHtml.ImageGuid;
        _gridStyle.Add("background-image", $"url('{_imgPath}')");
        if (_grid.BackgroundImageHtml.Stretch != AnyUiStretch.None)
        {
            _gridStyle.Add("background-repeat", "no-repeat");
            _gridStyle.Add("background-attachment", "fixed");
            _gridStyle.Add("background-size", "100% 100%");
        }
    }

    // ---------------------------------------------------------------
    // Outer wrapper div (handles margin + horizontal overflow clipping)
    // ---------------------------------------------------------------

    var _divOuter = new StylePile();
    _divOuter.SetSpecifics(margin: _grid.Margin);
    _divOuter.Set("white-space", "normal", add: true);
    _divOuter.Set("min-width", "0", add: true);
    _divOuter.Set("max-width", "100%", add: true);
    _divOuter.Set("overflow-x", "hidden", add: true);
    _divOuter.Set("box-sizing", "border-box", add: true);

    <div style="@_divOuter" data-source="AnyUiRenderGrid.razor outerDiv">
        <div style="@_gridStyle" data-source="AnyUiRenderGrid.razor cssGrid">

            @foreach (var _gch in _grid.Children ?? new List<AnyUiUIElement>())
            {
                if (_gch == null || (_gch.SkipForTarget & AnyUiTargetPlatform.Browser) > 0)
                    continue;

                var _gRow   = (_gch.GridRow    ?? 0) + 1;
                var _gCol   = (_gch.GridColumn ?? 0) + 1;
                var _gRowSp = _gch.GridRowSpan    ?? 1;
                var _gColSp = _gch.GridColumnSpan ?? 1;

                // When the spacer column was appended and a child spans "all" columns,
                // include the spacer so content still fills the full row.
                var _totalDefinedCols = _grid.ColumnDefinitions?.Count ?? 1;
                if (!_hasStarCol && _gColSp >= _totalDefinedCols)
                    _gColSp++;

                var _cellStyle = new StylePile(FormattableString.Invariant(
                    $"grid-row:{_gRow}/span {_gRowSp};grid-column:{_gCol}/span {_gColSp};min-width:0;"));

                // -- Vertical alignment --
                if (_gch is AnyUiFrameworkElement _gfe && _gfe.VerticalAlignment.HasValue)
                    switch (_gfe.VerticalAlignment.Value)
                    {
                        case AnyUiVerticalAlignment.Top:
                            _cellStyle.Set("align-self", "start",   add: true); break;
                        case AnyUiVerticalAlignment.Center:
                            _cellStyle.Set("align-self", "center",  add: true); break;
                        case AnyUiVerticalAlignment.Bottom:
                            _cellStyle.Set("align-self", "end",     add: true); break;
                        case AnyUiVerticalAlignment.Stretch:
                            _cellStyle.Set("align-self", "stretch", add: true);
                            _cellStyle.Set("height", "100%", add: true); break;
                    }

                // -- Horizontal content alignment --
                if (_gch is AnyUiControl _gcntl && _gcntl.HorizontalContentAlignment.HasValue)
                    switch (_gcntl.HorizontalContentAlignment.Value)
                    {
                        case AnyUiHorizontalAlignment.Center:
                            _cellStyle.Set("text-align", "center", add: true); break;
                        case AnyUiHorizontalAlignment.Right:
                            _cellStyle.Set("text-align", "right",  add: true); break;
                    }

                // -- WrapPanel: must be able to shrink so flex-wrap kicks in --
                if (_gch is AnyUiWrapPanel)
                    _cellStyle.Set("max-width", "100%", add: true);

                // -- AnyUiBorder: stretch to fill the cell (height + width) --
                if (_gch is AnyUiBorder)
                    _cellStyle.Set("align-self", "stretch", add: true);

                // -- Line height (must be on the parent of the text node) --
                if (_gch is AnyUiTextBlock _gchtb && _gchtb.LineHeightPercent.HasValue)
                    _cellStyle.Set("line-height",
                        FormattableString.Invariant($"{_gchtb.LineHeightPercent.Value:0.00}%"), add: true);

                <div style="@_cellStyle" data-source="AnyUiRenderGrid.razor cssGridCell">
                    <AnyUiRenderElem DisplayData="@DisplayData"
                                     Session="@Session"
                                     Parent="@Element"
                                     Element="@_gch"
                                     FillMode="@FillMode" />
                </div>
            }

        </div>
    </div>
}

@code {
    // resharper disable all

    [Parameter]
    public AnyUiDisplayDataHtml DisplayData { get; set; }

    [Parameter]
    public BlazorUI.Data.BlazorSession Session { get; set; }

    [Parameter]
    public AnyUiHtmlFillMode FillMode { get; set; }

    [Parameter]
    public AnyUiUIElement Parent { get; set; }

    protected AnyUiGrid _grid = null;

    [Parameter]
    public AnyUiUIElement Element
    {
        get { return _grid; }
        set
        {
            _grid = value as AnyUiGrid;
            if (_grid == null) return;

            // fix missing row/col definitions
            _grid.FixRowColDefs();

            // debug breakpoint helper (kept from original)
            if (_grid.RowDefinitions?.Count == 3 && _grid.ColumnDefinitions?.Count == 6
                && _grid.Children?.Count == 4
                && _grid.Children[0] is AnyUiWrapPanel wp && wp.Children?.Count == 1
                && wp.Children[0] is AnyUiSelectableTextBlock stb
                && stb.Text.StartsWith("ChargeId")
                && _grid.Children[3] is AnyUiStackPanel sp1 && sp1.Children?.Count == 1
                && sp1.Children[0] is AnyUiStackPanel sp2)
            {
                sp1.DebugTag = "CIDSP1";
                sp2.DebugTag = "CIDSP2";
            }
        }
    }
}
