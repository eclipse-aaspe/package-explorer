@page "/AnyUiFlyoutSelectFromList"
@using AnyUi
@using BlazorUI.Data
@inject BlazorUI.Data.AASService SubmodelService
@inject BlazorUI.Data.BlazorSession bi

@if(EventSession != null && DialogueData is AnyUiDialogueDataSelectFromList ddsfl)
{
	@* Native <select> (especially size>1 / multiple) is unreliable in iOS Safari inside modals.
	   Radio list works on all mobile browsers. *@

	<div class="modal-header">
		<h3 class="modal-title" id="flyoutSelectFromListTitle">@ddsfl.Caption</h3>
		<button type="button" class="close btn btn-backdrop" aria-label="Close"
			@onclick="() => LeaveResult(false)">
			<span aria-hidden="true">&times;</span>
		</button>
	</div>
	<div class="modal-body">
		<div class="list-group" role="radiogroup" aria-labelledby="flyoutSelectFromListTitle"
		     @ondblclick="@DblHandler">
			@if (ddsfl.ListOfItems != null)
			{
				for (int i = 0; i < ddsfl.ListOfItems.Count; i++)
				{
					var idx = i;
					var optId = $"flyoutListOpt_{idx}";
					<label class="list-group-item list-group-item-action d-flex align-items-center gap-2 mb-1"
					       style="cursor:pointer;">
						<input class="form-check-input flex-shrink-0 mt-0"
						       type="radio"
						       name="flyoutSelectFromListGroup"
						       id="@optId"
						       checked="@(_selectedIndex == idx)"
						       @onchange="@(() => OnSelectRadio(idx))" />
						<span class="flex-grow-1">@ddsfl.ListOfItems[i].Text</span>
					</label>
				}
			}
		</div>
	</div>
	<div class="modal-footer">

		<button type="button" class="btn btn-primary-light btn-lg" @onclick="() => LeaveResult(true)">OK</button>
	
	</div>
}

@code {
	[Parameter]
	public AnyUiHtmlEventSession EventSession { get; set; }

	[Parameter]
	public AnyUiDialogueDataBase DialogueData { get; set; }

	/// <summary>Sync UI highlight when DialogueData already has a selection (re-render).</summary>
	private int _selectedIndex = -1;

	protected override void OnParametersSet()
	{
		if (DialogueData is AnyUiDialogueDataSelectFromList ddsfl
		    && ddsfl.Result && ddsfl.ResultIndex >= 0)
			_selectedIndex = ddsfl.ResultIndex;
		else
			_selectedIndex = -1;
	}

	void OnSelectRadio(int index)
	{
		if (DialogueData is not AnyUiDialogueDataSelectFromList ddsfl || ddsfl.ListOfItems == null)
			return;
		if (index < 0 || index >= ddsfl.ListOfItems.Count)
			return;

		_selectedIndex = index;
		ddsfl.Result = true;
		ddsfl.ResultIndex = index;
		ddsfl.ResultItem = ddsfl.ListOfItems[index];
	}

	void DblHandler(MouseEventArgs e)
	{
		LeaveResult(true);
	}

	public void LeaveResult(bool result)
	{
		EventSession?.EndModal(result);
	}
}
