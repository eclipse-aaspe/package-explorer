@page "/test4"
@using AdminShellNS
@using Aas = AasCore.Aas3_1
@using Extensions
@using AnyUi
@using BlazorUI.Data
@inject BlazorUI.Data.AASService SubmodelService
@inject BlazorUI.Data.BlazorSession bi

@{
// resharper disable all
}

@{

    // access
    if (_panel == null)
        return;

    // because of not working with table, need an outer <div>
    var divOuterStyle = new StylePile();
    divOuterStyle.SetSpecifics(
        margin: _panel.Margin);
    // Layout wrapper: must not prevent flex-wrap inside descendants
    divOuterStyle.Set("white-space", "normal", add: true);
    // fill the available width of the containing block (important when inside a CSS Grid cell)
    divOuterStyle.Set("width", "100%", add: true);
    divOuterStyle.Set("min-width", "0", add: true);

    //
    // Eval different table attributes
    //

    var panelStyle = new StylePile();

    panelStyle.Add("background-color", _panel.Background?.HtmlRgb(), doNotSetIfNull: true);

    if (AnyUiDisplayDataHtml.DebugFrames)
        panelStyle.Set("border", "1px solid black", add: true);

    panelStyle.Set("width", "100%", add: true);
    panelStyle.Set("min-width", "0", add: true);
    panelStyle.Set("max-width", "100%", add: true);
    panelStyle.Set("display", "flex", add: true);
    panelStyle.Set("flex-wrap", "wrap", add: true);
    panelStyle.Set("align-items", "center", add: true);
    panelStyle.Set("align-content", "flex-start", add: true);
    panelStyle.Set("gap", "3px 4px", add: true);
    panelStyle.Set("box-sizing", "border-box", add: true);

    //
    // Render
    //

    <div style="@divOuterStyle">
        <div @attributes="@PanelAttributes" style="@panelStyle" data-source="AnyUiWrapPanel.razor">
            @{
                if (_panel?.Children != null)
                    foreach (var ch in _panel.Children)
                    {
                        @* Note: the wrap panel does NOT pass the FillMode! *@
                        <AnyUiRenderElem DisplayData="@DisplayData"
                                         Session="@Session"
                                         Parent="@Element"
                                         Element="@ch"
                                         FillMode="@AnyUiHtmlFillMode.None" />
                    }
            }
        </div>
    </div>
}

@code {
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object> PanelAttributes { get; set; }

    [Parameter]
    public AnyUiDisplayDataHtml DisplayData { get; set; }

    [Parameter]
    public BlazorUI.Data.BlazorSession Session { get; set; }

    protected AnyUiWrapPanel _panel = null;

    [Parameter]
    public AnyUiUIElement Parent { get; set; }

    [Parameter]
    public AnyUiWrapPanel Element
    {
        get { return _panel; }
        set
        {
            _panel = value;
            if (_panel == null)
                return;
        }
    }

    [Parameter]
    public AnyUiHtmlFillMode FillMode { get; set; }
}
