@using AdminShellNS
@using Aas = AasCore.Aas3_1
@using AdminShellNS;
@using Extensions
@using AnyUi
@using BlazorUI.Data
@inject BlazorUI.Data.AASService SubmodelService
@inject BlazorUI.Data.BlazorSession bi

@{
    // resharper disable all
}


@{

    // access
    if (_panel == null)
        return;

    var divOuterStyle = new StylePile();
    divOuterStyle.SetSpecifics(
        margin: _panel.Margin);
    // Layout wrapper: must not prevent flex-wrap inside descendants
    divOuterStyle.Set("white-space", "normal", add: true);

    //
    // Eval different table attributes
    //

    var panelStyle = new StylePile();

    panelStyle.Add("background-color", _panel.Background?.HtmlRgb(), doNotSetIfNull: true);

    if (AnyUiDisplayDataHtml.DebugFrames)
        panelStyle.Set("border", "1px solid black", add: true);

    panelStyle.Set("width", "100%", add: true);

    //
    // Render
    //

    <div style="@divOuterStyle">
        @if (_panel != null && _panel.Orientation == AnyUiOrientation.Horizontal)
        {
            @* Render the STACK HORIZONTALLY as a flex-row div.
               Note: the stack panel with horizontal orientation does NOT pass the FillMode! *@
            var horStyle = new StylePile(panelStyle);
            horStyle.Set("display", "flex", add: true);
            horStyle.Set("flex-direction", "row", add: true);
            horStyle.Set("flex-wrap", "wrap", add: true);
            horStyle.Set("align-items", "center", add: true);
            horStyle.Set("align-content", "flex-start", add: true);
            horStyle.Set("gap", "3px 4px", add: true);
            horStyle.Set("min-width", "0", add: true);
            <div @attributes="@PanelAttributes" style="@horStyle" data-source="AnyUiRenderStackPanel.razor HOR">
                @{
                    if (_panel?.Children != null)
                        foreach (var ch in _panel.Children)
                        {
                        <AnyUiRenderElem DisplayData="@DisplayData"
                                         Session="@Session"
                                         Parent="@Element"
                                         Element="@ch"
                                         FillMode="@AnyUiHtmlFillMode.None" />
                        }
                }
            </div>
        }

        @if (_panel.Orientation == null
            || (_panel != null && _panel.Orientation == AnyUiOrientation.Vertical))
        {
            @* Render the STACK VERTICALLY as a flex-column div.
               A <table> with table-layout:auto propagates its content min-width upward and
               causes the right panel to overflow at higher zoom levels. A flex container
               sizes itself by the flex algorithm — each row is a flex item with min-width:0
               so content wider than the available space overflows/clips inside the row
               rather than expanding the container. *@
            var verStyle = new StylePile(panelStyle);
            verStyle.Set("display", "flex", add: true);
            verStyle.Set("flex-direction", "column", add: true);
            verStyle.Set("min-width", "0", add: true);
            <div @attributes="@PanelAttributes" style="@verStyle" data-source="AnyUiRenderStackPanel.razor VER">
                @if (_panel?.Children != null)
                {
                    var stickyN = System.Math.Max(0, System.Math.Min(_panel.BrowserStickyFirstChildCount, _panel.Children.Count));
                    @if (stickyN > 0)
                    {
                        <div class="anyui-sticky-top-toolbar">
                            @for (int si = 0; si < stickyN; si++)
                            {
                                var chSticky = _panel.Children[si];
                                <div style="min-width:0;width:100%">
                                    <AnyUiRenderElem DisplayData="@DisplayData"
                                                     Session="@Session"
                                                     Element="@chSticky"
                                                     FillMode="@FillMode" />
                                </div>
                            }
                        </div>
                    }
                    @for (int i = stickyN; i < _panel.Children.Count; i++)
                    {
                        var ch = _panel.Children[i];
                        <div style="min-width:0;width:100%">
                            <AnyUiRenderElem DisplayData="@DisplayData"
                                             Session="@Session"
                                             Element="@ch"
                                             FillMode="@FillMode" />
                        </div>
                    }
                }
            </div>
        }
    </div>
}

@code {
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object> PanelAttributes { get; set; }

    [Parameter]
    public AnyUiDisplayDataHtml DisplayData { get; set; }

    [Parameter]
    public BlazorUI.Data.BlazorSession Session { get; set; }

    [Parameter]
    public AnyUiUIElement Parent { get; set; }

    [Parameter]
    public AnyUiHtmlFillMode FillMode { get; set; }

    protected AnyUiStackPanel _panel = null;

    [Parameter]
    public AnyUiStackPanel Element
    {
        get { return _panel; }
        set
        {
            _panel = value;
            if (_panel == null)
                return;
        }
    }

}
