<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ErrorOnDuplicatePublishOutputFiles>false</ErrorOnDuplicatePublishOutputFiles>
  </PropertyGroup>

  <!--
  Program.InferOptions() loads BlazorExplorer.options.json next to the executable.
  Use explicit Include+Link so bin/ and publish/ always get that exact filename (Debug vs Release sources).
  -->
  <ItemGroup Condition="'$(Configuration)' == 'Debug'">
    <None Include="BlazorExplorer.options-for-debug.json"
            Link="BlazorExplorer.options.json"
            CopyToOutputDirectory="PreserveNewest"
            CopyToPublishDirectory="PreserveNewest" />
  </ItemGroup>
  <ItemGroup Condition="'$(Configuration)' == 'Release'">
    <None Include="BlazorExplorer.options-for-release.json"
            Link="BlazorExplorer.options.json"
            CopyToOutputDirectory="PreserveNewest"
            CopyToPublishDirectory="PreserveNewest" />
  </ItemGroup>
  
  <ItemGroup>
    <Compile Remove="wwwroot\_content\**" />
    <Content Remove="wwwroot\_content\**" />
    <EmbeddedResource Remove="wwwroot\_content\**" />
    <None Remove="wwwroot\_content\**" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="Pages\Index.cshtml.cs" />
    <Content Remove="BlazorExplorer.options-for-release.json" />
    <Content Remove="BlazorExplorer.options-for-debug.json" />
    <Content Remove="local-identifier-presets.json" />
    <Content Remove="options-debug.MIHO.json" />
    <Content Remove="Pages\Component.razor" />
    <Content Remove="Pages\FetchData.cshtml" />
    <Content Remove="Pages\Index.cshtml" />
    <!-- Keep wwwroot/image/* as normal static web assets (publish + /image/... URLs). -->
  </ItemGroup>

  <ItemGroup>
    <None Remove="LICENSE.txt" />
    <None Remove="Resources\sample.png" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="LICENSE.txt">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </EmbeddedResource>
    <EmbeddedResource Include="Resources\sample.png" />
  </ItemGroup>

  <ItemGroup>
    <None Include="local-identifier-presets.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
    </None>
    <!-- Optional overlay; use: dotnet BlazorExplorer.dll -read-json options-debug.MIHO.json (see launchSettings) -->
    <None Include="options-debug.MIHO.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
    </None>
    <None Include="StylePile.cs">
      <Generator>TextTemplatingFileGenerator</Generator>
      <LastGenOutput>StylePile.txt</LastGenOutput>
    </None>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Blazor.Extensions.Canvas" Version="1.1.1" />
    <PackageReference Include="Microsoft.AspNetCore.Http.Abstractions" Version="2.3.0" />
    <PackageReference Include="RestSharp" Version="112.1.0" />
    <PackageReference Include="System.Data.SqlClient" Version="4.9.0" />
    <PackageReference Include="System.Formats.Asn1" Version="9.0.2" />
    <PackageReference Include="System.Text.Json" Version="9.0.2" />
    <PackageReference Include="Toolbelt.Blazor.SplitContainer" Version="2.1.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\AasxIntegrationBaseGdi\AasxIntegrationBaseGdi.csproj" />
    <ProjectReference Include="..\AasxIntegrationBase\AasxIntegrationBase.csproj" />
    <ProjectReference Include="..\AasxPackageLogic\AasxPackageLogic.csproj" />
    <ProjectReference Include="..\AnyUi\AnyUi.csproj" />
    <ProjectReference Include="..\UIComponents.Flags.Blazor\UIComponents.Flags.Blazor.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Update="start-browser.bat">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="start-server.bat">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="startup.bat">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="StylePile.txt">
      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
      <DependentUpon>StylePile.cs</DependentUpon>
    </None>
  </ItemGroup>

  <ItemGroup>
    <Service Include="{508349b6-6b84-4df5-91f0-309beebad82d}" />
  </ItemGroup>

  <!--
    Copy static web assets from NuGet packages and referenced projects (e.g. BlazorInputFile,
    Blazor.Extensions.Canvas, UIComponents.Flags.Blazor) into the bin output wwwroot/_content
    folder. Without this, the bin output only contains a runtime manifest with absolute
    paths to the local NuGet cache, which breaks deployment on other machines (e.g. Ubuntu).
  -->
  <Target Name="CopyExternalStaticWebAssetsToOutput" AfterTargets="Build" DependsOnTargets="ResolveCoreStaticWebAssets">
    <ItemGroup>
      <!--
        Collect assets from NuGet packages (SourceType=Package) and referenced projects
        (SourceType=Project) that need to be served under wwwroot/_content/<PackageName>/.
        Skip:
          - Discovered: the project's own wwwroot, already copied by the standard build.
          - .gz / .br: pre-compressed variants are only needed for production publish.
        Use %(FileName)%(Extension) from Identity (the real on-disk filename) because
        %(RelativePath) contains fingerprint placeholder tokens for Project assets.
      -->
      <_ExternalStaticWebAsset Include="@(StaticWebAsset)" Condition="'%(StaticWebAsset.SourceType)' != 'Discovered'&#xA;                 And !$([System.String]::Copy('%(StaticWebAsset.RelativePath)').EndsWith('.gz'))&#xA;                 And !$([System.String]::Copy('%(StaticWebAsset.RelativePath)').EndsWith('.br'))" />
    </ItemGroup>
    <Copy SourceFiles="@(_ExternalStaticWebAsset)" DestinationFiles="@(_ExternalStaticWebAsset->'$(OutDir)wwwroot/%(BasePath)/%(FileName)%(Extension)')" SkipUnchangedFiles="true" />
  </Target>

  <!--
    Eigenes wwwroot (css, js, bootstrap, image, …) landet beim SDK oft nicht physisch unter bin/.../wwwroot
    (nur Manifest mit lokalen Pfaden). Für XCopy-Deploy aus Debug muss wwwroot vollständig im Output liegen.
    Läuft nach CopyExternalStaticWebAssetsToOutput, damit _content/* von NuGet zuerst liegt.
  -->
  <Target Name="CopyProjectWwwrootToOutputDirectory" AfterTargets="CopyExternalStaticWebAssetsToOutput">
    <ItemGroup>
      <!-- *.* + bekannte extensionlose Dateien unter wwwroot -->
      <_AppWwwrootOut Include="wwwroot\**\*.*" Exclude="wwwroot\_content\**\*.*" />
      <_AppWwwrootOut Include="wwwroot\css\open-iconic\FONT-LICENSE;wwwroot\css\open-iconic\ICON-LICENSE" />
    </ItemGroup>
    <Copy SourceFiles="@(_AppWwwrootOut)"
          DestinationFiles="@(_AppWwwrootOut->'$(OutDir)wwwroot\%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />
  </Target>

  <!-- dotnet publish: OutDir copy is not enough — deploy folder must get package/project _content too (Linux/Ubuntu). -->
  <Target Name="CopyExternalStaticWebAssetsToPublishDirectory" AfterTargets="Publish" DependsOnTargets="ResolveCoreStaticWebAssets">
    <ItemGroup>
      <_ExternalStaticWebAssetPub Include="@(StaticWebAsset)" Condition="'%(StaticWebAsset.SourceType)' != 'Discovered'&#xA;                 And !$([System.String]::Copy('%(StaticWebAsset.RelativePath)').EndsWith('.gz'))&#xA;                 And !$([System.String]::Copy('%(StaticWebAsset.RelativePath)').EndsWith('.br'))" />
    </ItemGroup>
    <Copy SourceFiles="@(_ExternalStaticWebAssetPub)" DestinationFiles="@(_ExternalStaticWebAssetPub->'$(PublishDir)wwwroot/%(BasePath)/%(FileName)%(Extension)')" SkipUnchangedFiles="true" />
  </Target>

  <Target Name="CopyProjectWwwrootToPublishDirectory" AfterTargets="CopyExternalStaticWebAssetsToPublishDirectory">
    <ItemGroup>
      <_AppWwwrootPub Include="wwwroot\**\*.*" Exclude="wwwroot\_content\**\*.*" />
      <_AppWwwrootPub Include="wwwroot\css\open-iconic\FONT-LICENSE;wwwroot\css\open-iconic\ICON-LICENSE" />
    </ItemGroup>
    <Copy SourceFiles="@(_AppWwwrootPub)"
          DestinationFiles="@(_AppWwwrootPub->'$(PublishDir)wwwroot\%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />
  </Target>

  <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
    <TypeScriptTarget>ES2015</TypeScriptTarget>
    <TypeScriptJSXEmit>React</TypeScriptJSXEmit>
    <TypeScriptModuleKind>ES6</TypeScriptModuleKind>
    <TypeScriptCompileOnSaveEnabled>True</TypeScriptCompileOnSaveEnabled>
    <TypeScriptNoImplicitAny>False</TypeScriptNoImplicitAny>
    <TypeScriptRemoveComments>False</TypeScriptRemoveComments>
    <TypeScriptOutFile />
    <TypeScriptOutDir />
    <TypeScriptGeneratesDeclarations>False</TypeScriptGeneratesDeclarations>
    <TypeScriptNoEmitOnError>True</TypeScriptNoEmitOnError>
    <TypeScriptSourceMap>True</TypeScriptSourceMap>
    <TypeScriptMapRoot />
    <TypeScriptSourceRoot />
  </PropertyGroup>

</Project>
