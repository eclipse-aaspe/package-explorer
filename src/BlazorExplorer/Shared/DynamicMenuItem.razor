@using Microsoft.AspNetCore.Components.Web
@using MW.Blazor
@using AasxIntegrationBase
@using AnyUi
@using BlazorUI.Data
@using System.Globalization;
@inject IJSRuntime JsRuntime
@inject BlazorSession Session

@{
    // calculate max width of visible items
    var maxHeaderWidth = 5;
    foreach (var mi in MenuItems ?? Enumerable.Empty<AasxMenuItemBase>())
        if (mi is AasxMenuItem mii && !mii.Hidden)
            maxHeaderWidth = Math.Max(maxHeaderWidth, ("" + mii.Header).Length);
}

@for (var i = 0; i < (MenuItems?.Count ?? 0); i++)
{
    var mi = MenuItems[i];

    // not for Blazor?
    if ((mi.Filter & AasxMenuFilter.Blazor) == 0)
        continue;

    // better overview
    if (mi is AasxMenuSeparator)
    {
        <li><hr class="dropdown-divider"></li>

        // done
        continue;
    }

    // visible items?
    if (mi is AasxMenuItem mii && !mii.Hidden)
    {
        var itemPath = string.IsNullOrEmpty(NavMenuPath) ? $"{i}" : $"{NavMenuPath}_{i}";

        // clean header
        var header = ("" + mii.Header).Replace("_", "");

        if (mii.Childs == null || mii.Childs.Count < 1)
        {
            // normal item  
            if (Depth < 2)
            {
                <li class="nav-item">
                    <a class="nav-link active" id="nbi_@(mii.Name)" aria-current="page" @onclick="() => ClickOnItem(mii)" style="cursor: pointer;">
                        @header
                    </a>
                </li>
            }
            else
            {
                var itemDisabled = IsMenuItemDisabled(mii);
                // child item, but normal
                <li class="nav-item">
                    <a class="@(itemDisabled ? "dropdown-item disabled" : "dropdown-item")"
                       id="nbi_@(mii.Name)"
                       href="#"
                       aria-disabled="@(itemDisabled ? "true" : "false")"
                       tabindex="@(itemDisabled ? "-1" : "0")"
                       @onclick:preventDefault="true"
                       @onclick="() => OnDropdownLeafClick(mii)"
                       style="cursor: @(itemDisabled ? "default" : "pointer");">
                        <div style="position: relative">
                            @if(mii.IsCheckable)
                            {
                                if (mii.IsChecked)
                                {
                                    <span class="dropdown-item-texticon" id="nbi_dit_@(mii.Name)">&#x2611;</span>
                                }
                                else
                                {
                                    <span class="dropdown-item-texticon">&#x2610;</span>
                                }
                            }
                            <span style="display: inline-block; overflow: hidden; width: @((0.6*maxHeaderWidth).ToString(CultureInfo.InvariantCulture))rem; vertical-align:top">
                                @header
                            </span>
                            <span style="display: inline-block; vertical-align:top">
                                @("" + mii.InputGesture)
                            </span>
                        </div>
                    </a>
                </li>
            }
        }
        else
        {
            // item with children (toggle handled by main-layout.js — not data-bs-toggle)
            var styleDD = new StylePile().Add("cursor", "pointer");
            if (Depth >= 2)
            {
                styleDD.Add("color", "black!important");
                styleDD.Add("padding-left", "30px!important");
            }

            var subToggleId = "nbm_" + itemPath.Replace(".", "_");

            <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle" style="@styleDD" href="javascript:void(0)" id="@subToggleId" role="button" aria-expanded="false"
                   @onclick="@(() => OnBranchToggleAsync(subToggleId))"
                   @onclick:preventDefault="true"
                   @onclick:stopPropagation="true">
                    @mii.Header
                </a>
                <ul class="dropdown-menu" aria-labelledby="@subToggleId">
                        
                    @* Recursion !! *@

                    <CascadingValue Name="NavMenuPath" Value="@itemPath">
                        <DynamicMenuItem TopMenu="TopMenu"
                            MenuItems="mii.Childs"
                            Depth="(Depth + 1)" />
                    </CascadingValue>

                </ul>
            </li>
        }
    }
}


@code {

    [Parameter] public AasxMenu TopMenu { get; set; }

    [Parameter] public AasxMenu MenuItems { get; set; }

    [Parameter] public int Depth { get; set; }

    [CascadingParameter(Name = "NavMenuPath")] public string NavMenuPath { get; set; }

    private Task OnBranchToggleAsync(string toggleId) =>
        JsRuntime.InvokeVoidAsync("mainLayoutToggleDropDownById", toggleId).AsTask();

    private static readonly HashSet<string> AlwaysEnabledWithoutPackage =
        new(StringComparer.OrdinalIgnoreCase)
        {
            "new", "open", "filerepoquery", "exit", "about", "helpgithub", "faqgithub", "helpissues",
            "helpoptionsinfo", "filereponew", "filerepoopen", "filerepocreatelru",
        };

    /// <summary>Heuristic: Blazor has no WPF CommandBinding.CanExecute — approximate disabled state.</summary>
    private bool IsMenuItemDisabled(AasxMenuItem mii)
    {
        if (Session == null || mii == null)
            return false;
        if (mii.Childs != null && mii.Childs.Count > 0)
            return false;

        var name = mii.Name?.Trim();
        if (string.IsNullOrEmpty(name))
            return false;

        if (string.Equals(name, "CloseAux", StringComparison.OrdinalIgnoreCase))
            return Session.PackageCentral?.AuxAvailable != true;

        // Blazor: open package lives in PackageCentral.Main — Session.env is often unset (unlike WPF).
        var hasPackage = Session.PackageCentral?.MainAvailable == true;
        var edit = Session.EditMode;

        if (!hasPackage)
        {
            if (AlwaysEnabledWithoutPackage.Contains(name))
                return false;
            if (mii.RequiredInfos != AasxMenuArgReqInfo.None)
                return true;
            return NeedsOpenPackage(name);
        }

        if (!edit && RequiresEditModeWhenPackageOpen(name))
            return true;

        return false;
    }

    private static bool NeedsOpenPackage(string name)
    {
        if (AlwaysEnabledWithoutPackage.Contains(name))
            return false;
        if (name.StartsWith("import", StringComparison.OrdinalIgnoreCase))
            return true;
        if (name.StartsWith("export", StringComparison.OrdinalIgnoreCase))
            return true;

        return name.ToLowerInvariant() switch
        {
            "save" or "saveas" or "fixandfinalize" or "verify" or "close" or "checkandfix" => true,
            "closeaux" or "openaux" => true,
            "sign" or "validatecertificate" or "encrypt" or "decrypt" => true,
            "assesssmt" or "comparesmt" => true,
            "addbaseaddress" or "clearbasecredentials" or "connectextended" or "apiuploadassistant"
                or "apiuploadfiles" or "createrepofromapi" => true,
            "connectsecure" or "connectopcua" or "connectrest" or "connectintegrated"
                or "filerepoconnectrepository" => true,
            "printasset" or "exportsmd" => true,
            _ => false,
        };
    }

    /// <summary>Actions that change package content — disabled in view mode when a package is open.
    /// Close / CloseAux are intentionally excluded: user must be able to close without edit mode.</summary>
    private static bool RequiresEditModeWhenPackageOpen(string name)
    {
        var n = name.ToLowerInvariant();
        return n is "save" or "saveas" or "fixandfinalize" or "verify" or "checkandfix"
            or "sign" or "validatecertificate" or "encrypt" or "decrypt";
    }

    private void OnDropdownLeafClick(AasxMenuItem mii)
    {
        if (IsMenuItemDisabled(mii))
            return;
        ClickOnItem(mii);
    }

    public void ClickOnItem(AasxMenuItemBase mi)
    {
        // toggle menu item?
        if (mi is AasxMenuItem mii && mii.IsCheckable)
        {
            // switch state
            mii.IsChecked = !mii.IsChecked;

            // prepare header again            
            var header = (mii.IsChecked) ? "&#x2611;" : "&#x2610;";

            // send of
            JsRuntime.InvokeVoidAsync("setNavBarItem", "nbi_dit_" + mii.Name, header);
        }

        // in any case call the top menu
        var ticket = new AasxMenuActionTicket()
        {
            MenuItem = mi
        };
        TopMenu?.ActivateAction(mi, ticket);
    }

}