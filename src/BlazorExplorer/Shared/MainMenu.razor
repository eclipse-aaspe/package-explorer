@inherits LayoutComponentBase
@using AdminShellNS;
@using AasxIntegrationBase
@using AasxPackageLogic;
@using AasxPackageLogic.PackageCentral;
@using BlazorUI.Data;
@inject IJSRuntime JsRuntime
@inject BlazorUI.Data.BlazorSession Session

@* IDTA links, AAS, Burger; horizontales Menü ab 800px (app-navbar-expand-800 in site.css) *@
<nav class="navbar navbar-dark bg-primary app-top-navbar app-navbar-expand-800"
     style="position:relative; overflow:visible">
    <div class="container-fluid app-top-navbar-bar px-2">
        <a class="navbar-brand app-top-navbar-idta flex-shrink-0 py-0 me-1 me-sm-2" href="#" aria-label="IDTA">
            <img src="/image/Logo_IDTA_Custom.png" height="24" alt="IDTA" class="app-top-navbar-idta-img">
        </a>
        <a class="navbar-brand app-top-navbar-brand flex-shrink-0" href="#" aria-label="AAS">
            <img src="/image/IDTA_AAS-Logo_Circle.png" height="30" width="30" alt="">
        </a>

        <button class="navbar-toggler flex-shrink-0 py-2 ms-auto"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbarSupportedContent"
                aria-controls="navbarSupportedContent"
                aria-expanded="false"
                aria-label="Menü öffnen">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse app-top-navbar-inner"
             id="navbarSupportedContent">
            <ul class="navbar-nav mb-2 app-top-navbar-nav" style="flex-shrink:0">
                <DynamicMenuItem TopMenu="Session.MainMenu?.Menu"
                                MenuItems="Session.MainMenu?.Menu"
                                Depth="1" />
            </ul>
            <div class="d-flex flex-nowrap gap-1 align-items-center app-top-navbar-actions">
                <button class="btn btn-sm btn-primary-light" type="button"
                        @onclick='async () => await ClickOnItem("NavigateBack")'>
                    &#x25C0;
                </button>
                <button class="btn btn-sm btn-primary-light" type="button"
                        @onclick='async () => await ClickOnItem("NavigateHome")'>
                    &#x25B6;
                </button>
            </div>
        </div>
    </div>
</nav>

@code
{
    public async Task ClickOnItem(string menuItemName)
    {
        var mi = Session.MainMenu?.Menu?.FindName(menuItemName);
        if (mi != null)
        {
            var ticket = new AasxMenuActionTicket()
            {
                MenuItem = mi
            };
            await Session.MainMenu?.Menu.ActivateAction(mi, ticket);
        }
    }
}
