<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
             xmlns:m="clr-namespace:UraniumUI.Icons.MaterialSymbols;assembly=UraniumUI.Icons.MaterialSymbols"
             xmlns:cz="clr-namespace:FunctionZero.Maui.Controls;assembly=FunctionZero.Maui.Controls"
             xmlns:local="clr-namespace:MauiTestTree"
             x:Class="MauiTestTree.MainPage"
             x:DataType="local:MainViewModel"
             x:Name="RootOfPage"
             Title="My2App">

    <ContentPage.Resources>
        <local:InverseBoolConverter
            x:Key="MyInverseBoolConverter" />

        <local:EnumToIntParamterizedConverter
            x:Key="MyEnumToIntParamterizedConverter" />
    </ContentPage.Resources>

    <!-- Window background -->
    <ContentPage.Background>
        <AppThemeBinding
            Light="{StaticResource White}"
            Dark="{StaticResource Gray900}" />
    </ContentPage.Background>

    <!-- Navbar in IDTA blue, if dark theme -->
    <Shell.BackgroundColor>
        <AppThemeBinding
            Light="{StaticResource Gray100}"
            Dark="{StaticResource Primary}" />
    </Shell.BackgroundColor>
   
    <!-- For menues to work, it has to be a navigation page; per default this is given by
         having the shell for the application. -->
    <!-- The classic menu is for Windows and macOS Catalyst options. Not shown on any
         mobile devices -->
    <ContentPage.MenuBarItems>
    </ContentPage.MenuBarItems>

    <!-- The Shell/ Navigation bar renders a top bar on mobile devices. 
         This contains multiple items (extra ordinary) on the left side.-->
    <Shell.TitleView>
        <Grid ColumnDefinitions="Auto,*,Auto"
              HeightRequest="{OnPlatform Android=56, WinUI=48, iOS=44}" 
              Padding="0">
            <!-- IDTA logo or AAS/ AssetIds -->
            <local:OrgOrAasLabel 
                Grid.Row="0" Grid.Column="0" 
                IsVisible="{Binding IsScreenIdiomDesktop, Converter={StaticResource MyInverseBoolConverter}}"
                WidthRequest="{Binding ScreenIdiom, Converter={StaticResource MyEnumToIntParamterizedConverter}, ConverterParameter=220|180|140}" 
                AasId="{Binding AasId}" AssetId="{Binding AssetId}"
                ShowLabels="{Binding IsScreenIdiomPhone, Converter={StaticResource MyInverseBoolConverter}}"
                FileDropReceived="Window_Drop"/>

            <!-- Just a foreach-loop over the given items -->
            <!-- Note: For phones this should be empty! -->
            <HorizontalStackLayout x:Name="TitleViewMenuItems"
                Grid.Row="0" Grid.Column="1"
                IsVisible="{Binding IsScreenIdiomDesktop, Converter={StaticResource MyInverseBoolConverter}}"
                Margin="20,2,0,2" Spacing="8"
                BindableLayout.ItemsSource="{Binding MobileTopRootMenuHandles}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="{x:Null}">
                        <Button Clicked="OnTitleViewButton_Clicked"
                                Text="{Binding .}" 
                                Margin="0,0,0,0"
                                Padding="8,0,8,0" BackgroundColor="Transparent" CornerRadius="6"
                                BorderColor="Transparent" BorderWidth="1.5"
                                FontAttributes="Bold" FontSize="12">
                            <Button.TextColor>
                                <AppThemeBinding
                                    Light="{StaticResource Gray600}"
                                    Dark="{StaticResource Gray200}" />
                            </Button.TextColor>
                            <Button.Background>
                                <AppThemeBinding
                                    Light="#30ffffff"
                                    Dark="#30000000" />
                            </Button.Background>
                        </Button>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </HorizontalStackLayout>

            <HorizontalStackLayout x:Name="TitleViewFixItems"
                Grid.Row="0" Grid.Column="2"
                Margin="8,0,0,0" Spacing="8">

                <!-- Move current element up/ down for quick element transition -->
                <Button x:Name="MoveUpToolBarButton"
                    Clicked="ToolBarItem_Clicked" Padding="0" Margin="0"
                    BorderColor="Transparent" BorderWidth="0"
                    Background="Transparent">
                    <Button.ImageSource>
                        <FontImageSource
                            FontFamily="MaterialOutlined"
                            Glyph="{x:Static m:MaterialOutlined.Move_up}"
                            Size="24">
                            <FontImageSource.Color>
                                <AppThemeBinding
                                    Light="{StaticResource ToolbarIconColorLight}"
                                    Dark="{StaticResource ToolbarIconColorDark}" />
                            </FontImageSource.Color>
                        </FontImageSource>
                    </Button.ImageSource>
                </Button>

                <Button x:Name="MoveDownToolBarButton"
                    Clicked="ToolBarItem_Clicked" Padding="0" Margin="0"
                    BorderColor="Transparent" BorderWidth="0"
                    Background="Transparent">
                    <Button.ImageSource>
                        <FontImageSource
                            FontFamily="MaterialOutlined"
                            Glyph="{x:Static m:MaterialOutlined.Move_down}"
                            Size="24">
                            <FontImageSource.Color>
                                <AppThemeBinding
                                    Light="{StaticResource ToolbarIconColorLight}"
                                    Dark="{StaticResource ToolbarIconColorDark}" />
                            </FontImageSource.Color>
                        </FontImageSource>
                    </Button.ImageSource>
                </Button>

                <!-- Resize active panels for quick access elements/ element attributes -->
                <Button x:Name="LeftPanelToolBarButton"
                    Clicked="ToolBarItem_Clicked" Padding="0" Margin="0"
                    BorderColor="Transparent" BorderWidth="0"
                    Background="Transparent">
                    <Button.ImageSource>
                        <FontImageSource
                            FontFamily="MaterialOutlined"
                            Glyph="{x:Static m:MaterialOutlined.Left_panel_open}"
                            Size="24">
                            <FontImageSource.Color>
                                <AppThemeBinding
                                    Light="{StaticResource ToolbarIconColorLight}"
                                    Dark="{StaticResource ToolbarIconColorDark}" />
                            </FontImageSource.Color>
                        </FontImageSource>
                    </Button.ImageSource>
                </Button>

                <Button x:Name="RightPanelToolBarButton"
                    Clicked="ToolBarItem_Clicked" Padding="0" Margin="0"
                    BorderColor="Transparent" BorderWidth="0"
                    Background="Transparent">
                    <Button.ImageSource>
                        <FontImageSource
                            FontFamily="MaterialOutlined"
                            Glyph="{x:Static m:MaterialOutlined.Right_panel_open}"
                            Size="24">
                            <FontImageSource.Color>
                                <AppThemeBinding
                                    Light="{StaticResource ToolbarIconColorLight}"
                                    Dark="{StaticResource ToolbarIconColorDark}" />
                            </FontImageSource.Color>
                        </FontImageSource>
                    </Button.ImageSource>
                </Button>

            </HorizontalStackLayout>
        </Grid>
    </Shell.TitleView>

    <!-- The main grid consists of a column left (elements) and a column right (element attributes)
         and a divider (between). -->
    <Grid x:Name="MainGrid" ColumnDefinitions="300,8,*" RowDefinitions="4,*,4,24">
        <!-- A small gray line on top to extend the shell -->
        <BoxView
            Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3">
            <BoxView.BackgroundColor>
                <AppThemeBinding
                    Light="{DynamicResource Gray100}"
                    Dark="{StaticResource Primary}" />
            </BoxView.BackgroundColor>
        </BoxView>
        
        <!-- Left Panel -->
        <Grid RowDefinitions="Auto, Auto, *" ColumnDefinitions="*"
            x:Name="LeftContent" 
            Grid.Row="1" Grid.Column="0">

            <!-- Right margin rage because of scrollbor of tree -->
            <local:OrgOrAasLabel 
                Grid.Row="0" Grid.Column="0" 
                MaximumHeightRequest="72"
                Margin="8,8,18,8"
                IsVisible="{Binding IsScreenIdiomDesktop}"
                AasId="{Binding AasId}" AssetId="{Binding AssetId}"
                FileDropReceived="Window_Drop"/>

            <Grid Grid.Row="1" Grid.Column="0" 
                  ColumnDefinitions="Auto, Auto">

                <Label Grid.Row="0" Grid.Column="0" 
                       VerticalOptions="Center"
                       Margin="10,0,0,0"
                       Text="Multi select" />

                <Switch Grid.Row="0" Grid.Column="1" 
                        Margin="10,0,0,0"
                        HorizontalOptions="Start" WidthRequest="56" MaximumWidthRequest="56"
                        OnColor="{StaticResource PrimaryLight}"
                        ThumbColor="{StaticResource Primary}"
                        IsToggled="{Binding MultiSelectOn}"/>

            </Grid>

            <local:DiplayVisualAasxElements 
                Grid.Row="2" Grid.Column="0" 
                SelectedItemChanged="DisplayElements_SelectedItemChanged"
                x:Name="DisplayElements"/>
        </Grid>

        <!-- Divider -->
        <BoxView
            x:Name="Divider"
            Grid.Row="1" Grid.Column="1"             
            WidthRequest="8">
            <BoxView.BackgroundColor>
                <AppThemeBinding
                    Light="{DynamicResource Gray100}"
                    Dark="{StaticResource Primary}" />
            </BoxView.BackgroundColor>
        </BoxView>
        
        <!-- a little handle in the divide -->
        <Border Grid.Row="1" Grid.Column="1" 
                MaximumHeightRequest="48"
                MaximumWidthRequest="2"
                StrokeShape="RoundRectangle 6"
                StrokeThickness="0"
                Background="DarkGray" />
        
        <!-- an invisible box to have a large pan handle -->
        <BoxView
            x:Name="TraspDivider"
            Grid.Row="1" Grid.Column="1" 
            BackgroundColor="Transparent"
            MaximumHeightRequest="48"
            Margin="-12,0,-12,0">
            <BoxView.GestureRecognizers>
                <PanGestureRecognizer PanUpdated="OnDividerPanUpdated"/>
            </BoxView.GestureRecognizers>
        </BoxView>

        <!-- Right Panel -->
        <ContentView
            x:Name="RightContent"
            Grid.Row="1" Grid.Column="2">

            <local:DispEditAasxEntityMaui x:Name="DispEditEntityPanel"/>

        </ContentView>
        
        <!-- A small gray line on top to extend the shell -->
        <BoxView
            Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3">
            <BoxView.BackgroundColor>
                <AppThemeBinding
                    Light="{DynamicResource Gray100}"
                    Dark="{StaticResource Primary}" />
            </BoxView.BackgroundColor>
        </BoxView>
            
        <!-- Log line -->
        <Grid x:Name="LogGrid"
              Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
              ColumnDefinitions="*, Auto, Auto, Auto"
              Padding="16,2,16,2"
              Background="{Binding LogBg}">

            <Label x:Name="LogLine"
                Grid.Row="0" Grid.Column="0"
                Margin="0,0,8,0"
                VerticalOptions="Center" VerticalTextAlignment="Center"
                Text="{Binding LogLine}"
                LineBreakMode="NoWrap"
                FontSize="11"
                TextColor="{Binding LogFg}"/>

            <Border Grid.Row="0" Grid.Column="1"
                    StrokeThickness="1.0"
                    Padding="4,1,4,1"
                    StrokeShape="RoundRectangle 4"
                    Background="{Binding AttentionBg}">
                <Border.Stroke>
                    <AppThemeBinding
                        Light="{StaticResource White}"
                        Dark="{StaticResource Gray900}" />
                </Border.Stroke>

                <Label x:Name="AttentionLabel"
                    WidthRequest="80"
                    HorizontalOptions="End"
                    VerticalOptions="Center" VerticalTextAlignment="Center"
                    HorizontalTextAlignment="Center"
                    Text="{Binding AttentionText}"
                    FontSize="11"
                    TextColor="{Binding AttentionFg}">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="ReportControls_Tapped"/>
                    </Label.GestureRecognizers>
                </Label>
            </Border>

            <local:NavIconButton
                x:Name="StatusLineClearButton"
                Grid.Row="0" Grid.Column="2"
                Margin="4,0,4,0"
                Glyph="{x:Static m:MaterialOutlined.Mop}"
                TextColor="{Binding LogFg}"
                Clicked="ReportControls_Click"/>

            <local:NavIconButton
                x:Name="ReportButton"
                Grid.Row="0" Grid.Column="3"
                Margin="4,0,4,0"
                Glyph="{x:Static m:MaterialOutlined.Notes}"
                TextColor="{Binding LogFg}"
                Clicked="ReportControls_Click"/>
        </Grid>


    </Grid>

</ContentPage>
