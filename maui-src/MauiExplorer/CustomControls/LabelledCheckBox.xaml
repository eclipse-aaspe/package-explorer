<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MauiTestTree"
             x:Class="MauiTestTree.LabelledCheckBox">
    <HorizontalStackLayout x:Name="MainLayout"
                           Spacing="{Binding Padding, Source={RelativeSource AncestorType={x:Type local:LabelledCheckBox}}}"
                           VerticalOptions="Center"
                           BackgroundColor="{Binding Background, Source={RelativeSource AncestorType={x:Type local:LabelledCheckBox}}}">

        <CheckBox x:Name="CheckBoxControl"
                  IsChecked="{Binding IsChecked, Source={RelativeSource AncestorType={x:Type local:LabelledCheckBox}}}"
                  CheckedChanged="CheckBoxControl_CheckedChanged"
                  VerticalOptions="Center"/>

        <!--
        <Label x:Name="LabelControl"
               Text="{Binding Text, Source={x:Reference Name=This}}"
               TextColor="{Binding Foreground, Source={x:Reference Name=This}}"
               VerticalOptions="Center"/>
        -->

        <Label x:Name="LabelControl"
           Text="{Binding Text, Source={RelativeSource AncestorType={x:Type local:LabelledCheckBox}}}"
           TextColor="{Binding Foreground, Source={RelativeSource AncestorType={x:Type local:LabelledCheckBox}}}"
           FontSize="{Binding FontSize, Source={RelativeSource AncestorType={x:Type local:LabelledCheckBox}}}"
           FontFamily="{Binding FontFamily, Source={RelativeSource AncestorType={x:Type local:LabelledCheckBox}}}"
           FontAttributes="{Binding FontAttributes, Source={RelativeSource AncestorType={x:Type local:LabelledCheckBox}}}"
           VerticalTextAlignment="{Binding VerticalTextAlignment, Source={RelativeSource AncestorType={x:Type local:LabelledCheckBox}}}"
           HorizontalTextAlignment="{Binding HorizontalTextAlignment, Source={RelativeSource AncestorType={x:Type local:LabelledCheckBox}}}"
           VerticalOptions="Center" />

    </HorizontalStackLayout>
</ContentView>
